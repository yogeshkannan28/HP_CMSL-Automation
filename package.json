{
  "name": "hp-cmsl-automation",
  "version": "2.0.0",
  "description": "HP CMSL PowerShell Test Automation Framework using TypeScript + Jest (POM pattern), a persistent PowerShell pool for parallel execution, and an Ollama-backed agentic SDET monitor exposed over MCP",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint-ps-strings.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run test:readonly && npm run test:mutating",
    "test:readonly": "jest --config jest.readonly.config.ts --verbose",
    "test:mutating": "jest --config jest.mutating.config.ts --verbose --runInBand",
    "test:unit": "jest --config jest.unit.config.ts --verbose",
    "test:bios": "jest --config jest.readonly.config.ts --testPathPattern=tests/bios-device --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/bios-device --verbose --runInBand",
    "test:softpaq": "jest --config jest.readonly.config.ts --testPathPattern=tests/softpaq-mgmt --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/softpaq-mgmt --verbose --runInBand",
    "test:repo": "jest --config jest.readonly.config.ts --testPathPattern=tests/softpaq-repo --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/softpaq-repo --verbose --runInBand",
    "test:firmware": "jest --config jest.readonly.config.ts --testPathPattern=tests/firmware --verbose",
    "test:consent": "jest --config jest.readonly.config.ts --testPathPattern=tests/consent --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/consent --verbose --runInBand",
    "test:notifications": "jest --config jest.readonly.config.ts --testPathPattern=tests/notifications --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/notifications --verbose --runInBand",
    "test:docks": "jest --config jest.readonly.config.ts --testPathPattern=tests/docks --verbose && jest --config jest.mutating.config.ts --testPathPattern=tests/docks --verbose --runInBand",
    "test:retail": "jest --config jest.readonly.config.ts --testPathPattern=tests/retail --verbose",
    "preflight": "node -r @swc-node/register src/core/platformGuard.ts",
    "test:report": "npm run test:readonly -- --json --outputFile=reports/test-results-readonly.json && npm run test:mutating -- --json --outputFile=reports/test-results-mutating.json",
    "agent:run": "node -r @swc-node/register src/agent/cli.ts --once",
    "agent:watch": "node -r @swc-node/register src/agent/cli.ts --watch",
    "mcp:serve": "node -r @swc-node/register src/mcp/server.ts"
  },
  "keywords": ["hp", "cmsl", "automation", "testing", "powershell", "typescript", "ollama", "agent", "mcp"],
  "author": "yogeshkannan28",
  "license": "MIT",
  "devDependencies": {
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.36",
    "@swc-node/register": "^1.10.9",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.25.0",
    "zod": "^3.23.8"
  }
}
